# Docker network
DOCKER_NETWORK_DRIVER=bridge

# Container names
KAFKA_CONTAINER_NAME=kafka-broker
KAFKA_UI_CONTAINER_NAME=kafka-ui
POSTGRES_CONTAINER_NAME=postgres
PGBOUNCER_CONTAINER_NAME=pgbouncer
MYSQL_CONTAINER_NAME=mysql
PROXYSQL_CONTAINER_NAME=proxysql
MONGO_CONTAINER_NAME=mongo
MONGO_EXPRESS_CONTAINER_NAME=mongo-express
API_GATEWAY_CONTAINER_NAME=api-gateway
AUTH_SERVICE_CONTAINER_NAME=auth-service
NOTIFICATION_SERVICE_CONTAINER_NAME=notification-service

# Images
KAFKA_IMAGE=apache/kafka:latest
KAFKA_UI_IMAGE=kafbat/kafka-ui:latest
POSTGRES_IMAGE=postgres:16-alpine
PGBOUNCER_IMAGE=edoburu/pgbouncer
MYSQL_IMAGE=mysql:8.0
PROXYSQL_IMAGE=proxysql/proxysql
MONGO_IMAGE=mongo:7.0
MONGO_EXPRESS_IMAGE=mongo-express:latest

# Kafka
KAFKA_PORT_HOST=9092
KAFKA_PORT_CONTAINER_EXTERNAL=9092
KAFKA_NODE_ID=1
KAFKA_PROCESS_ROLES=broker,controller
KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka-broker:9093
KAFKA_LISTENERS=INTERNAL://0.0.0.0:29092,EXTERNAL://0.0.0.0:9092,CONTROLLER://0.0.0.0:9093
KAFKA_ADVERTISED_LISTENERS=INTERNAL://kafka-broker:29092,EXTERNAL://localhost:9092
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=INTERNAL:PLAINTEXT,EXTERNAL:PLAINTEXT,CONTROLLER:PLAINTEXT
KAFKA_INTER_BROKER_LISTENER_NAME=INTERNAL
KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_CLUSTER_ID=replace-with-kafka-cluster-id
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1
KAFKA_HEALTHCHECK_CMD=/opt/kafka/bin/kafka-cluster.sh cluster-id --bootstrap-server localhost:9092 || exit 1
KAFKA_HEALTHCHECK_INTERVAL=10s
KAFKA_HEALTHCHECK_TIMEOUT=5s
KAFKA_HEALTHCHECK_RETRIES=5

# Kafka UI
KAFKA_UI_PORT_HOST=9093
KAFKA_UI_PORT_CONTAINER=8080
KAFKA_UI_CLUSTER_NAME=production-grade-cluster
KAFKA_UI_BOOTSTRAP_SERVERS=kafka-broker:29092
KAFKA_UI_DYNAMIC_CONFIG_ENABLED=true

# PostgreSQL (via PgBouncer)
DB_POSTGRES_HOST=pgbouncer
DB_POSTGRES_PORT=6432
DB_POSTGRES_PORT_CONTAINER=5432
POSTGRES_PORT=5432
POSTGRES_PORT_HOST=5432
POSTGRES_HEALTHCHECK_CMD=pg_isready -U svc_user
POSTGRES_HEALTHCHECK_INTERVAL=10s
POSTGRES_HEALTHCHECK_TIMEOUT=5s
POSTGRES_HEALTHCHECK_RETRIES=5
PGBOUNCER_PORT_HOST=6432
PGBOUNCER_PORT_CONTAINER=5432
PGBOUNCER_DB_HOST=postgres
DB_POSTGRES_NAME=service_db
DB_POSTGRES_USER=svc_user
DB_POSTGRES_PASSWORD=change_me
DB_POSTGRES_POOL_MIN=2
DB_POSTGRES_POOL_MAX=10
PGBOUNCER_AUTH_TYPE=scram-sha-256
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=100
PGBOUNCER_DEFAULT_POOL_SIZE=20

# MySQL (via ProxySQL)
DB_MYSQL_HOST=proxysql
DB_MYSQL_PORT=6033
DB_MYSQL_POOL_MAX=10
MYSQL_PORT_HOST=3306
MYSQL_PORT_CONTAINER=3306
MYSQL_HEALTHCHECK_HOST=localhost
MYSQL_HEALTHCHECK_INTERVAL=10s
MYSQL_HEALTHCHECK_TIMEOUT=5s
MYSQL_HEALTHCHECK_RETRIES=5
MYSQL_HEALTHCHECK_START_PERIOD=30s
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=mysql_db
MYSQL_USER=svc_user
MYSQL_PASSWORD=change_me
PROXYSQL_PORT_HOST=6033
PROXYSQL_PORT_CONTAINER=6033
PROXYSQL_ADMIN_PORT_HOST=6032
PROXYSQL_ADMIN_PORT_CONTAINER=6032

# MongoDB (direct, driver handles pooling)
DB_MONGO_URI=mongodb://mongo:27017/service_db
DB_MONGO_POOL_MAX=10
MONGO_PORT_HOST=27017
MONGO_PORT_CONTAINER=27017
MONGO_HEALTHCHECK_CMD=mongosh --quiet -u $$MONGO_INITDB_ROOT_USERNAME -p $$MONGO_INITDB_ROOT_PASSWORD --authenticationDatabase admin --eval "db.adminCommand('ping').ok" || exit 1
MONGO_HEALTHCHECK_INTERVAL=10s
MONGO_HEALTHCHECK_TIMEOUT=5s
MONGO_HEALTHCHECK_RETRIES=5
MONGO_HEALTHCHECK_START_PERIOD=20s
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=change_me
MONGO_INITDB_DATABASE=service_db
MONGO_EXPRESS_PORT_HOST=8081
MONGO_EXPRESS_PORT_CONTAINER=8081
MONGO_EXPRESS_MONGODB_URL=mongodb://root:change_me@mongo:27017/
MONGO_EXPRESS_BASICAUTH=false

# Services Ports
API_GATEWAY_PORT=5000
AUTH_SERVICE_PORT=5004
NOTIFICATION_SERVICE_PORT=5013
PAYMENT_SERVICE_PORT=5020

# Docker Port (host-side, api-gateway only)
DOCKER_API_GATEWAY_PORT=4139

# Internal service URLs (used by api-gateway to reach services inside Docker network)
AUTH_SERVICE_URL=http://auth-service:5004
NOTIFICATION_SERVICE_URL=http://notification-service:5013
PAYMENT_SERVICE_URL=http://payment-service:5020
