datadir="/var/lib/proxysql"

admin_variables=
{
  admin_credentials="admin:admin"
  mysql_ifaces="0.0.0.0:6032"
}

mysql_variables=
{
  threads=4
  max_connections=2048
  interfaces="0.0.0.0:6033"
  server_version="8.0.27"
  monitor_username="root"
  monitor_password="rootsecret"
  monitor_ping_interval=10000
  connect_timeout_server=3000
}

# Backend MySQL server
mysql_servers=
(
  {
    address="mysql"
    port=3306
    hostgroup=0
    status="ONLINE"
    weight=1
    max_connections=100
  }
)

# App user that services use to connect
mysql_users=
(
  {
    username="svc_user"
    password="secret"
    default_hostgroup=0
    max_connections=100
    default_schema="mysql_db"
    active=1
  }
)

# Pass-through query rules: writes to HG 0, reads to HG 0 (single node setup)
mysql_query_rules=
(
  {
    rule_id=1
    active=1
    match_pattern="^SELECT .* FOR UPDATE"
    destination_hostgroup=0
    apply=1
  },
  {
    rule_id=2
    active=1
    match_pattern="^SELECT"
    destination_hostgroup=0
    apply=1
  }
)
